{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "hydrolox",
      "camelcase": "Hydrolox",
      "title": "Hydrolox",
      "scope": "source.hydrolox",
      "file-types": [
        "hlox"
      ],
      "injection-regex": "^hydrolox$",
      "class-name": "TreeSitterHydrolox"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0",
    "description": "Tree-sitter grammar for the low level Hydrolox programming language",
    "authors": [
      {
        "name": "TheMasterofWorlds99",
        "email": "eleyow@outlook.com",
        "url": "https://github.com/TheMasterofWorlds99"
      }
    ],
    "links": {
      "repository": "https://github.com/TheMasterofWorlds99/Hydrolox/tree/main",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}