extern func i32 printf(fmt: str, ...); // Takes a fat pointer, but 
                                       // unwraps it to C during the code Generation

func f64 customLN(x: f64) {
  xt: f64 = (x - 1.0) / (x + 1.0);
  xSQ: f64 = xt * xt;
  sum: f64 = 0.0;
  currentTerm: f64 = xt;

  for (i: i32 = 0; i < 100; i++) {
    sum = sum + (currentTerm / (2.0 * (f64)i + 1.0));
    currentTerm = currentTerm * xSQ;
  }

  return 2.0 * sum;
}

func f64 exp(x: f64) {
  sum: f64 = 1.0;
  term: f64 = 1.0;

  for (i: i32 = 0; i < 100; i++) {
    term = term * (x / (f64)(i + 1));
    sum = sum + term;
  }
  return sum;
}

func f64 pow(base: f64, expo: f64) {
  if (base == 0.0) { return 0.0; }
  if (expo == 0.0) { return 1.0; }

  return exp(expo * customLN(base));
}

func f64 estimateE(n: f64) {
  x: f64 = 1 + (1 / n);
  return pow(x, n + 0.5);
}

func i32 start() {
    printf("Testing the pow, ln and estimateE functions.\n");

    n: f64 = 10000000;

    printf("We are estimating e with an n of %f\n", n);

    e: f64 = estimateE(n);

    printf("Now we'll estimate e with just exp(1)\n");

    e2: f64 = exp(1.0);

    printf("The estimated e using estiamteE is: %.15f\n", e);
    printf("The estimated e using exp(1.0) is: %.15f\n", e2);
    return 0;
}
